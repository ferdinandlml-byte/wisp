# Base de datos (Supabase gratis)
DATABASE_URL=postgresql://usuario:password@db.supabase.co:5432/postgres

# Redis (Upstash gratis)
REDIS_URL=redis://default:password@tu-instancia.upstash.io:6379

# JWT
SECRET_KEY=cambia-esto-por-una-clave-segura-de-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# MikroTik
MIKROTIK_HOST=192.168.1.1
MIKROTIK_USER=admin
MIKROTIK_PASSWORD=tu-password

# WhatsApp (Evolution API)
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=tu-api-key
EVOLUTION_INSTANCE=siswisp
